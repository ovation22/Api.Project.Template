{
    "$schema": "http://json.schemastore.org/template",
    "author": "John Callaway",
    "classifications": ["Web", "WebAPI", "ASP.NET", "Clean Architecture"],
    "identity": "Api.Project.Template",
    "name": ".NET Api Project Template",
    "shortName": "api-project",
    "sourceName": "Api.Project.Template",
    "preferNameDirectory": true,
    "tags": {
        "language": "C#",
        "type":"project"
    },
    "sources": [{
        "exclude": [
            ".git/**/*",
            "**/[Bb]in/**",
            "**/[Oo]bj/**",
            ".template.config/**/*",
            "**/*.filelist",
            "**/*.user",
            "**/*.lock.json"
        ]
    }],
    "symbols": {
        "projectShortName": {
            "type": "generated",
            "generator": "regex",
            "datatype": "string",
            "parameters": {
                "source": "name",
                "steps": [
                    { "regex": "\\.", "replacement": "" }
                ]
            },
            "replaces": "ApiProjectTemplate",
            "fileRename": "ApiProjectTemplate"
        },
        "projectKebabName": {
            "type": "generated",
            "generator": "regex",
            "datatype": "string",
            "parameters": {
                "source": "name",
                "steps": [
                    { "regex": "\\.", "replacement": "-" }
                ]
            },
            "replaces": "api-project-template"
        }
    }
}